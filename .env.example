# Base URLs
VITE_API_BASE_URL=http://127.0.0.1:4000/api/v1
VITE_IMAGE_BASE_URL=https://cdn.example.com/images
VITE_SOCKET_URL=ws://127.0.0.1:4000
VITE_APP_VERSION=1.0.0

# Third Party Keys (Do not put real keys here)
VITE_GOOGLE_MAP_KEY=your_google_maps_key
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_RAZORPAY_KEY=your_razorpay_key

# Feature Flags
VITE_ENABLE_WALLET=true
VITE_ENABLE_CHAT=false
